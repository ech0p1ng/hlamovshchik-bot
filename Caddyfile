{$MINIO__DOMAIN} {

    encode gzip

    # Общие заголовки
    header {
        Access-Control-Allow-Origin *
        Cache-Control "public, max-age=31536000, immutable"
    }

    # --- Thumbnails ---
    handle_path /t/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}

        reverse_proxy minio:9000 {
            header_up Host {host}

            # Контент-тайпы
            @jpg path_regexp jpg \.jpg$
            header_down @jpg Content-Type image/jpeg

            @jpeg path_regexp jpeg \.jpeg$
            header_down @jpeg Content-Type image/jpeg

            @png path_regexp png \.png$
            header_down @png Content-Type image/png

            @webp path_regexp webp \.webp$
            header_down @webp Content-Type image/webp
        }
    }

    # --- Originals ---
    handle_path /i/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}

        reverse_proxy minio:9000 {
            header_up Host {host}

            # Контент-тайпы
            @jpg path_regexp jpg \.jpg$
            header_down @jpg Content-Type image/jpeg

            @jpeg path_regexp jpeg \.jpeg$
            header_down @jpeg Content-Type image/jpeg

            @png path_regexp png \.png$
            header_down @png Content-Type image/png

            @webp path_regexp webp \.webp$
            header_down @webp Content-Type image/webp
        }
    }

    # --- Кэширование ---
    handle_path /t/* /i/* {
        cache {
            path /data/caddy-cache
            ttl 24h
            stale 12h
        }
    }
}

# --- MinIO Admin Console ---
{$MINIO__ADMIN_DOMAIN} {
    reverse_proxy {$MINIO__ENDPOINT_SECURE}

    header {
        Strict-Transport-Security "max-age=31536000"
    }
}
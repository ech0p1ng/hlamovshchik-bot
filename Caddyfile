{$MINIO__DOMAIN} {
    encode gzip

    header {
        Access-Control-Allow-Origin *
        Cache-Control "public, max-age=31536000, immutable"
    }

    # Path matchers для изображений
    @jpg path /t/*.jpg /t/*.jpeg /i/*.jpg /i/*.jpeg
    @png path /t/*.png /i/*.png
    @webp path /t/*.webp /i/*.webp

    # Принудительно Content-Type
    header @jpg Content-Type image/jpeg
    header @png Content-Type image/png
    header @webp Content-Type image/webp

    # Thumbnails
    handle_path /t/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}
        reverse_proxy {$MINIO__ENDPOINT} {
            # Пробрасываем правильный Host
            header_up Host {$MINIO__ENDPOINT}
            # Отключаем buffering для MinIO
            flush_interval -1
        }
    }

    # Originals
    handle_path /i/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}
        reverse_proxy {$MINIO__ENDPOINT} {
            header_up Host {$MINIO__ENDPOINT}
            flush_interval -1
        }
    }
}

{$MINIO__ADMIN_DOMAIN} {
    reverse_proxy {$MINIO__ENDPOINT_SECURE} {
        header_up Host {$MINIO__ENDPOINT_SECURE}
        # Для консоли важны WebSocket
        header_up Upgrade {http.request.header.Upgrade}
        header_up Connection {http.request.header.Connection}
    }

    header {
        Strict-Transport-Security "max-age=31536000"
    }
}
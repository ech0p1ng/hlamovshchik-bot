{$MINIO__DOMAIN} {
    encode gzip

    header {
        Access-Control-Allow-Origin *
        Cache-Control "public, max-age=31536000, immutable"
    }

    # --- Thumbnails ---
    handle_path /t/* {
        route {
            reverse_proxy minio:9000 {
                header_up Host {host}
            }

            # Перезаписываем Content-Type после прокси
            handle_response {
                @jpg path *.jpg
                header Content-Type image/jpeg @jpg

                @jpeg path *.jpeg
                header Content-Type image/jpeg @jpeg

                @png path *.png
                header Content-Type image/png @png

                @webp path *.webp
                header Content-Type image/webp @webp
            }
        }
    }

    # --- Originals ---
    handle_path /i/* {
        route {
            reverse_proxy minio:9000 {
                header_up Host {host}
            }

            handle_response {
                @jpg path *.jpg
                header Content-Type image/jpeg @jpg

                @jpeg path *.jpeg
                header Content-Type image/jpeg @jpeg

                @png path *.png
                header Content-Type image/png @png

                @webp path *.webp
                header Content-Type image/webp @webp
            }
        }
    }

    # --- Кэширование ---
    handle_path /t/* /i/* {
        cache {
            path /data/caddy-cache
            ttl 24h
            stale 12h
        }
    }
}

{$MINIO__ADMIN_DOMAIN} {
    reverse_proxy {$MINIO__ENDPOINT_SECURE}

    header {
        Strict-Transport-Security "max-age=31536000"
    }
}
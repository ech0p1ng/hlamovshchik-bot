{$MINIO__DOMAIN} {
    encode gzip

    header {
        Access-Control-Allow-Origin *
        Cache-Control "public, max-age=31536000, immutable"
    }

    # Thumbnails
    handle_path /t/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}
        reverse_proxy minio:${MINIO__PORT} {
            header_up Host {host}
        }
        # Простейший вариант: Content-Type через path matcher
        @jpg path *.jpg
        @jpeg path *.jpeg
        @png path *.png
        @webp path *.webp

        header @jpg Content-Type image/jpeg
        header @jpeg Content-Type image/jpeg
        header @png Content-Type image/png
        header @webp Content-Type image/webp
    }

    # Originals
    handle_path /i/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}
        reverse_proxy minio:${MINIO__PORT} {
            header_up Host {host}
        }

        @jpg path *.jpg
        @jpeg path *.jpeg
        @png path *.png
        @webp path *.webp

        header @jpg Content-Type image/jpeg
        header @jpeg Content-Type image/jpeg
        header @png Content-Type image/png
        header @webp Content-Type image/webp
    }
}

{$MINIO__ADMIN_DOMAIN} {
    reverse_proxy {$MINIO__ENDPOINT_SECURE}

    header {
        Strict-Transport-Security "max-age=31536000"
    }
}
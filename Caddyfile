{$MINIO__DOMAIN} {
    encode gzip

    # Проксируем /i/* в /private-bucket/*
    handle /i/* {
        rewrite * /private-bucket{path}
        reverse_proxy http://{$MINIO__ENDPOINT} {
            # Убираем лишние заголовки
            header_up Host {http.request.host}
            # Не добавляем Authorization
        }
    }

    handle /t/* {
        rewrite * /private-bucket{path}
        reverse_proxy http://{$MINIO__ENDPOINT} {
            header_up Host {http.request.host}
        }
    }

    header {
        Access-Control-Allow-Origin *
        X-Content-Type-Options nosniff
    }
}
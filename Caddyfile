{$MINIO__DOMAIN} {
    encode gzip

    header {
        Access-Control-Allow-Origin *
        Cache-Control "public, max-age=31536000, immutable"
    }

    # Thumbnails
    handle_path /t/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}

        reverse_proxy minio:{$MINIO__PORT} {
            header_up Host {host}
        }

        # Content-Type после ответа
        @jpg path *.jpg *.jpeg
        @png path *.png
        @webp path *.webp

        handle_response @jpg {
            header Content-Type image/jpeg
        }
        handle_response @png {
            header Content-Type image/png
        }
        handle_response @webp {
            header Content-Type image/webp
        }
    }

    # Originals
    handle_path /i/* {
        rewrite * /{$MINIO__BUCKET_NAME}{uri}

        reverse_proxy minio:{$MINIO__PORT} {
            header_up Host {host}
        }

        @jpg path *.jpg *.jpeg
        @png path *.png
        @webp path *.webp

        handle_response @jpg {
            header Content-Type image/jpeg
        }
        handle_response @png {
            header Content-Type image/png
        }
        handle_response @webp {
            header Content-Type image/webp
        }
    }
}

{$MINIO__ADMIN_DOMAIN} {
    reverse_proxy {$MINIO__ENDPOINT_SECURE}

    header {
        Strict-Transport-Security "max-age=31536000"
    }
}